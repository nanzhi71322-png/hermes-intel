# Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=
ALLOWED_CHAT_IDS=
# Legacy alias still supported by config/settings.py
TELEGRAM_CHAT_ID=

# DeepSeek API key used through the OpenAI-compatible client.
DEEPSEEK_API_KEY=

# Phase 1 trading (default: paper mode)
TRADING_MODE=paper
TRADING_TESTNET=true
EXCHANGE_ID=binance
DEFAULT_SYMBOL=BTC/USDT
MAX_POSITION_USD=50
MAX_DAILY_LOSS_USD=20
MAX_OPEN_POSITIONS=3

BINANCE_API_KEY=
BINANCE_SECRET=

# Daily report (optional)
DAILY_REPORT_ENABLED=true
DAILY_REPORT_HOUR_UTC=1
DAILY_REPORT_MINUTE_UTC=0
OBSERVATION_DAYS=3
SEND_REPORT_ON_START=false

# 部署见 .env.deploy.example；远程快照: scripts/pull_remote_env_to_local.py
