# 复制为 .env.deploy.local 后填写，勿提交真实密码
# cp .env.deploy.example .env.deploy.local

DEPLOY_SSH_HOST=
DEPLOY_SSH_PORT=22
DEPLOY_SSH_USER=root
DEPLOY_SSH_PASSWORD=

DEPLOY_REMOTE_PATH=/opt/hermes/tg-bot
DEPLOY_ENV_PATH=/opt/hermes/.env

TRADING_MODE=paper
TRADING_TESTNET=true
EXCHANGE_ID=binance
DEFAULT_SYMBOL=BTC/USDT
MAX_POSITION_USD=50
MAX_DAILY_LOSS_USD=20
MAX_OPEN_POSITIONS=3

BINANCE_API_KEY=
BINANCE_SECRET=

# Daily observation report (3 days)
DAILY_REPORT_ENABLED=true
DAILY_REPORT_HOUR_UTC=1
DAILY_REPORT_MINUTE_UTC=0
OBSERVATION_DAYS=3
SEND_REPORT_ON_START=true
